---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { FaCheck } from "react-icons/fa";
import { getCollection, render } from "astro:content";

const homepage = await getListPage("homepage", "-index");
const { features, factionIntro } = homepage.data;

const characters = (await getCollection("characters")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base>
  <!-- Hero -->
  <section
    class="relative flex min-h-[90vh] w-full items-center justify-center"
    style="background-image: url('/images/shop_daytime.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;"
  >
    <div class="flex flex-col items-center px-4 text-center">
      <img
        src="/images/logo_transparent.png"
        alt="You Are a Frog"
        class="w-72 drop-shadow-lg md:w-[1200px]"
      />
    </div>
  </section>
  <!-- /Hero -->

  <!-- Game sections -->
  {
    features.map((feature, index: number) => (
      <>
        <section class={`section-sm ${index % 2 === 0 && "bg-gradient"}`}>
          <div class="container">
            <div class="row items-center justify-between">
              <div class={`mb:md-0 mb-6 md:col-5 ${index % 2 !== 0 && "md:order-2"}`}>
                <ImageMod
                  src={feature.image}
                  height={480}
                  width={520}
                  alt={feature.title}
                  format="webp"
                />
              </div>
              <div class={`md:col-7 lg:col-6 ${index % 2 !== 0 && "md:order-1"}`}>
                <h2 set:html={markdownify(feature.title)} class="mb-4" />
                <p set:html={markdownify(feature.content)} class="mb-8 text-lg" />
                <ul>
                  {feature.bulletpoints.map((bullet: string) => (
                    <li class="relative mb-4 pl-6">
                      <FaCheck className={"absolute left-0 top-1.5"} />
                      <span set:html={markdownify(bullet)} />
                    </li>
                  ))}
                </ul>
                {feature.button.enable && (
                  <a class="btn btn-primary mt-5" href={feature.button.link}>
                    {feature.button.label}
                  </a>
                )}
              </div>
            </div>
          </div>
        </section>
        {index === 2 && (
          <section class="py-12 bg-gradient">
            <div class="container">
              <div class="flex flex-wrap items-end justify-center gap-6 md:gap-10">
                {[
                  { src: "/images/elixir_of_rage.gif", label: "Elixir of Rage" },
                  { src: "/images/pure_spice.gif", label: "Pure Spice" },
                  { src: "/images/scholar_draught.gif", label: "Scholar's Draught" },
                  { src: "/images/sleep_potion.gif", label: "Sleep Potion" },
                  { src: "/images/dry_heat.gif", label: "Dry Heat" },
                  { src: "/images/fluffy_cloud.gif", label: "Fluffy Cloud" },
                ].map(({ src, label }) => (
                  <figure class="flex flex-col items-center gap-3">
                    <img src={src} alt={label} class="h-56 w-auto object-contain" />
                    {/* <figcaption class="text-sm text-text-light">{label}</figcaption> */}
                  </figure>
                ))}
              </div>
            </div>
          </section>
        )}
      </>
    ))
  }
  <!-- /Game sections -->

  <!-- Trailer -->
  <section
    class="relative py-24"
    style="background-image: url('/images/shop_night.jpg'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0" style="background-color: rgba(10, 8, 18, 0.65);"></div>
    <div class="container relative z-10">
      <div class="flex flex-col items-center gap-12 md:flex-row">
        <div class="w-full md:w-5/12">
          <p class="mb-3 text-xl uppercase tracking-widest" style="color: #a78bfa;">Check out the trailer!</p>
          <h2 class="mb-5 text-white">Take a sneak peek into the core mechanics of You're a Frog?</h2>
        </div>
        <div class="w-full md:w-7/12">
          <div class="relative w-full overflow-hidden rounded-xl" style="padding-bottom: 56.25%;">
            <iframe
              class="absolute inset-0 h-full w-full"
              src="https://www.youtube.com/embed/W94CV-V6GIw"
              title="You're a Frog? — Trailer"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Trailer -->

  <!-- Faction intro -->
  <section class="py-24 text-center" style="background-color: #0e0b14;">
    <div class="container">
      <p class="mb-4 text-4xl font-bold uppercase tracking-widest" style="color: #a78bfa;">
        {factionIntro.tag}
      </p>
      <h2 class="mb-6 text-white">{factionIntro.title}</h2>
      <p class="mx-auto max-w-2xl text-lg" style="color: #9ca3af;">
        {factionIntro.content}
      </p>
    </div>
  </section>
  <!-- /Faction intro -->

  <!-- Characters -->
  {
    characters.map(async (character) => {
      const { Content } = await render(character);
      const { name, faction, factionColor, bgColor, image, portraitSide, bottomAlign } = character.data;
      const isLeft = portraitSide === "left";
      return (
        <section class={bottomAlign ? "pt-20 pb-20 md:pb-0" : "py-20"} style={`background-color: ${bgColor};`}>
          <div class="container">
            <div class={`flex flex-col items-center gap-12 ${isLeft ? "md:flex-row" : "md:flex-row-reverse"}`}>
              <div class={`flex w-full flex-shrink-0 justify-center md:w-5/12 ${bottomAlign ? "self-end" : ""}`}>
                <img
                  src={image}
                  alt={name}
                  class={`w-auto object-contain object-bottom drop-shadow-xl ${bottomAlign ? "max-h-[600px]" : "max-h-[480px]"}`}
                />
              </div>
              <div class="w-full md:w-7/12">
                <p class="mb-3 text-xs uppercase tracking-widest" style={`color: ${factionColor};`}>
                  {faction}
                </p>
                <h2 class="mb-5 text-white">{name}</h2>
                <div class="text-lg leading-relaxed" style="color: #d1d5db;">
                  <Content />
                </div>
              </div>
            </div>
          </div>
        </section>
      );
    })
  }
  <!-- /Characters -->

  <!-- Feedback -->
  <section class="py-24 text-center bg-gradient">
    <div class="container">
      <h2 class="mb-4">We Want Your Feedback!</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-text-light">
        Scan the QR code to fill in a questionnaire. It helps us a lot!
      </p>
      <img
        src="/images/qr_code_questionnaire.png"
        alt="Feedback QR code"
        class="mx-auto w-48"
      />
    </div>
  </section>
  <!-- /Feedback -->

</Base>
