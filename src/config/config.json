  },

  "google_tag_manager": {
    "enable": false,
    "gtm_id": "GTM-XXXXXX"
  },

  "disqus": {
    "enable": false,
    "shortname": "",
    "settings": {}
  },

 "metadata": {
  "meta_author": "Tinier Alchemists",
  "meta_image": "/images/preview-image.png",
