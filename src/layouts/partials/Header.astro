---
import ThemeSwitcher from "@/components/ThemeSwitcher.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";

const { main } = menu;
const { navigation_button } = config;
const { pathname } = Astro.url;
---

<header class="header fixed top-0 z-30 w-full">
  <nav class="navbar container relative flex items-center justify-center">
    <!-- mobile toggler -->
    <input id="nav-toggle" type="checkbox" class="hidden" />
    <label
      for="nav-toggle"
      class="absolute right-0 cursor-pointer flex items-center lg:hidden text-text-dark dark:text-white"
    >
      <svg id="show-button" class="h-6 fill-current block" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
      <svg id="hide-button" class="h-6 fill-current hidden" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"></polygon>
      </svg>
    </label>

    <!-- nav links -->
    <ul
      id="nav-menu"
      class="navbar-nav hidden w-full pb-6 text-center lg:flex lg:w-auto lg:space-x-8 lg:pb-0"
    >
      {
        main.map((item) => (
          <li class="nav-item">
            <a
              href={item.url}
              class={`nav-link block ${(pathname === `${item.url}/` || pathname === item.url) && "active"}`}
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- theme switcher + nav button -->
    <div class="absolute right-0 hidden lg:flex items-center gap-4">
      <ThemeSwitcher />
      {navigation_button.enable && (
        <a
          class="nav-button btn btn-sm transition"
          href={navigation_button.link}
          target={navigation_button.link.startsWith("http") ? "_blank" : "_self"}
          rel="noopener"
        >
          {navigation_button.label}
        </a>
      )}
    </div>
  </nav>
</header>

<script>
  let scrollController: AbortController | null = null;

  function initHeader() {
    const header = document.querySelector(".header") as HTMLElement;
    if (!header) return;

    scrollController?.abort();
    scrollController = null;

    if (window.location.pathname !== "/") {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
      const hero = document.querySelector("section") as HTMLElement;
      if (!hero) return;

      scrollController = new AbortController();
      const update = () => {
        if (window.scrollY > hero.offsetHeight * 0.9) {
          header.classList.add("scrolled");
        } else {
          header.classList.remove("scrolled");
        }
      };
      window.addEventListener("scroll", update, {
        passive: true,
        signal: scrollController.signal,
      });
      update();
    }
  }

  document.addEventListener("astro:page-load", initHeader);
</script>
